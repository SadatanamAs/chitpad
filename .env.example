# ================================================================
#  chitpad Flutter — Environment Variables
#  cp .env.example .env   ← NEVER commit .env
#  These are injected at build time via envied — not bundled as
#  plaintext. The generated env.g.dart is gitignored.
# ================================================================

# API — point to your local backend
API_BASE_URL=http://localhost/api/v1

# Supabase GoTrue — must match your self-hosted Supabase
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=your-supabase-anon-key
